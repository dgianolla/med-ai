# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# Groq (transcrição de áudio)
GROQ_API_KEY=gsk_...

# Supabase
SUPABASE_URL=https://seu-projeto.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
DATABASE_URL=postgresql://postgres:SUA_SENHA@db.seu-projeto.supabase.co:5432/postgres

# Upstash Redis
UPSTASH_REDIS_URL=https://...upstash.io
UPSTASH_REDIS_TOKEN=...

# wts.chat
WTS_API_URL=https://api.wts.chat
WTS_API_KEY=...
WTS_CONFIRMATION_CHANNEL_ID=uuid-do-canal-de-confirmacao
WTS_CONFIRMATION_TEMPLATE_ID=uuid-do-template-de-confirmacao
WTS_CONFIRMATION_CALLBACK_URL=https://seu-backend.com/webhook/confirmations/status
WTS_CONFIRMATION_ENABLE_BOT=true
WTS_CONFIRMATION_HIDDEN_SESSION=true
WTS_CONFIRMATION_FORCE_START_SESSION=false

# wts.chat chatbot trigger
WTS_CHATBOT_SEND_URL=https://api.helena.run/chat/v1/chatbot/send
WTS_CONFIRMATION_CHATBOT_ID=83de878d-aae7-474f-aa65-32e5a45e7e34
WTS_CONFIRMATION_TRIGGER_DELAY_SECONDS=3

# App
PORT=8000
ENVIRONMENT=development
SESSION_TTL_SECONDS=1800
WEBHOOK_SECRET=algum_secret_para_validar_webhook
